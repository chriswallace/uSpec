# Dependencies
node_modules/

# OS files
.DS_Store

# Editor
.idea/
.vscode/
*.swp

# Cursor
.cursor/mcp.json

# Environment / secrets
.env
.env.*
*.pem

# MCP configs — may contain access tokens or internal tooling references
# .mcp.json.bak is a template; users create .mcp.json locally
.mcp.json
.mcp.json.bak

# Claude Code local settings — contains user-specific paths and plugins
.claude/settings.local.json

# Generated skills (created by sync-skills.sh via firstrun)
# Only firstrun is committed — other skills are synced on demand
.claude/skills/*/
!.claude/skills/firstrun/
.agents/skills/*/
!.agents/skills/firstrun/
